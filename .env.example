# Variáveis de ambiente para o sistema de reporte de erros
# Copie este arquivo para .env.local e preencha com seus valores
# OU configure manualmente no painel da Vercel

# SMTP Configuration
SMTP_HOST=smtp.seu-email.com
SMTP_PORT=587
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-senha

# Email Configuration
REPORT_FROM_EMAIL=seu-email@dominio.com
REPORT_TO_EMAIL=email-para-receber-relatorios@gmail.com
